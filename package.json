{
  "name": "bot-avrilou",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Bot Discord de moderation, annonces et protection anti-raid",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "start:prod": "node dist/deploy-commands.js && node dist/index.js",
    "build": "tsc",
    "check": "tsc --noEmit",
    "deploy:commands": "tsx src/deploy-commands.ts"
  },
  "dependencies": {
    "discord.js": "^14.19.3",
    "dotenv": "^16.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}

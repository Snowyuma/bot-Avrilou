# Portail développeur Discord > Application
DISCORD_TOKEN=
CLIENT_ID=
# Serveur de test : les commandes y sont déployées instantanément
GUILD_ID=

# Salon dans lequel /publier est autorisé
ANNOUNCEMENT_CHANNEL_ID=
# Salon privé recevant les alertes et actions de modération
MOD_LOG_CHANNEL_ID=

# Protection anti-raid
ANTI_RAID_ENABLED=true
RAID_JOIN_LIMIT=8
RAID_WINDOW_SECONDS=15
# Âge minimum du compte en heures (0 désactive ce contrôle)
MIN_ACCOUNT_AGE_HOURS=24
# Rôle attribué aux nouveaux membres si défini (rôle de quarantaine conseillé)
QUARANTINE_ROLE_ID=
